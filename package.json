{
  "name": "mongo-grid-mcp",
  "version": "1.1.0",
  "description": "MCP server per MongoDB GridFS — upload/download/relay/watch/cleanup",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "tsc && node --test dist/test/gridfs.test.js",
    "docker:build": "docker build -t mongo-grid-mcp .",
    "docker:test": "echo {\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2025-03-26\",\"capabilities\":{},\"clientInfo\":{\"name\":\"test\",\"version\":\"1.0.0\"}}} | docker run -i --rm -e MONGODB_URI=mongodb://admin:secret@host.docker.internal:27017 -e MONGODB_DB=gridfs_store mongo-grid-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "mongodb": "^7.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.5.3"
  },
  "private": true
}
